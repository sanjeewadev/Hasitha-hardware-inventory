<UserControl x:Class="InventorySystem.UI.Views.POSView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="1200"
             Background="#F8FAFC">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="450"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="5" Margin="0,0,0,20"
                    BorderBrush="#CBD5E1" BorderThickness="1.5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="🔍" Margin="15,0,10,0" VerticalAlignment="Center" Foreground="#94A3B8"/>
                    <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Scan barcode or type name..."
                             BorderThickness="0" Background="Transparent"
                             Height="40" VerticalContentAlignment="Center" FontSize="14"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Products}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.SelectProductCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Margin="0,0,12,12" Width="150" Height="90"
                                    Background="White" BorderBrush="#CBD5E1" BorderThickness="1" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" 
                                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="12">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#E2E8F0" BlurRadius="4" ShadowDepth="2" Opacity="0.2"/>
                                            </Border.Effect>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <StackPanel Grid.Row="0" VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding Name}" TextWrapping="Wrap" FontWeight="SemiBold" 
                                                               Foreground="#1E293B" FontSize="12"/>
                                                </StackPanel>

                                                <Grid Grid.Row="1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding SellingPrice, StringFormat='Rs {0:N0}'}" 
                                                               Foreground="#059669" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                                    <Border Grid.Column="1" Background="#F1F5F9" CornerRadius="4" Padding="6,2" BorderBrush="#E2E8F0" BorderThickness="1">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Quantity}" FontSize="10" FontWeight="Bold" Foreground="#64748B"/>
                                                            <TextBlock Text="{Binding Unit}" FontSize="9" Foreground="#64748B" Margin="2,0,0,0" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush" Value="#059669"/>
                                                <Setter Property="Background" Value="#F0FDFA"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <Border Grid.Column="1" Background="White" BorderBrush="#CBD5E1" BorderThickness="1,0,0,0">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Current Order" FontSize="20" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,20"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,8,0">
                    <ItemsControl ItemsSource="{Binding Cart}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="8" BorderBrush="#CBD5E1" BorderThickness="1" Margin="0,0,0,12" Padding="15">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#E2E8F0" BlurRadius="5" ShadowDepth="2" Opacity="0.5"/>
                                    </Border.Effect>

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="Bold" FontSize="14" Foreground="#1E293B" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Total, StringFormat='Rs {0:N2}'}" FontWeight="Bold" FontSize="15" Foreground="#0F172A" VerticalAlignment="Center" Margin="0,0,15,0"/>

                                            <Button Grid.Column="2" Content="✕" 
                                                    Command="{Binding DataContext.RemoveFromCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}" 
                                                    Foreground="#94A3B8" Background="Transparent" BorderThickness="0" 
                                                    Cursor="Hand" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Padding="5,0">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Foreground" Value="#EF4444"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>

                                        <Grid Grid.Row="1" Margin="0,15,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Orientation="Vertical">
                                                <TextBlock Text="Quantity" FontSize="11" FontWeight="SemiBold" Foreground="#94A3B8" Margin="0,0,0,4"/>
                                                <Border Background="#F8FAFC" CornerRadius="6" BorderBrush="#CBD5E1" BorderThickness="1" Height="38" Padding="5,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBox Text="{Binding QuantityStr, UpdateSourceTrigger=PropertyChanged}" Width="50" BorderThickness="0" Background="Transparent" TextAlignment="Center" VerticalContentAlignment="Center" FontSize="15" FontWeight="Bold" Foreground="#334155"/>
                                                        <TextBlock Text="{Binding Unit}" FontSize="12" Foreground="#64748B" VerticalAlignment="Center" Margin="2,0,5,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="5,0,5,5">
                                                <TextBlock Text="{Binding StandardPrice, StringFormat='Orig: {0:N2}'}" 
                                                           FontSize="12" FontWeight="SemiBold" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,0,0,2"/>

                                                <TextBlock Text="{Binding DiscountCode, StringFormat='Code: {0}'}" 
                                                           FontSize="11" FontWeight="Bold" Foreground="#F59E0B" HorizontalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DiscountCode}" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" Orientation="Vertical">
                                                <TextBlock Text="Unit Price" FontSize="11" FontWeight="SemiBold" Foreground="#94A3B8" Margin="0,0,0,4" HorizontalAlignment="Right"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <Button Content="MD" Command="{Binding ApplyMaxDiscountCommand}" 
                                                            Background="#FFF7ED" Foreground="#F97316" FontSize="10" FontWeight="Bold" 
                                                            BorderThickness="1" BorderBrush="#FFEDD5" Width="34" Height="38" Margin="0,0,8,0" Padding="0" Cursor="Hand" ToolTip="Apply Full Discount">
                                                        <Button.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="6"/>
                                                            </Style>
                                                        </Button.Resources>
                                                    </Button>

                                                    <Border Background="White" CornerRadius="6" BorderBrush="#CBD5E1" BorderThickness="1" Height="38">
                                                        <TextBox Text="{Binding PriceStr, UpdateSourceTrigger=PropertyChanged}" Width="90" TextAlignment="Right" VerticalContentAlignment="Center" Padding="0,0,8,0" FontSize="15" BorderThickness="0" Background="Transparent" Foreground="{Binding PriceTextColor}" FontWeight="Bold"/>
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <StackPanel Grid.Row="2" VerticalAlignment="Bottom">
                    <Border BorderBrush="#CBD5E1" BorderThickness="0,1,0,0" Padding="0,20,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,5" Visibility="{Binding HasDiscount, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Total Savings" FontSize="14" FontWeight="SemiBold" Foreground="#059669" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding TotalDiscount, StringFormat='- Rs {0:N2}'}" 
                                               FontSize="16" FontWeight="Bold" Foreground="#059669" HorizontalAlignment="Right"/>
                                </Grid>

                                <Grid Grid.Row="1">
                                    <TextBlock Text="Total Amount" FontSize="16" Foreground="#64748B" VerticalAlignment="Bottom"/>
                                    <TextBlock Text="{Binding GrandTotal, StringFormat='Rs {0:N2}'}" 
                                               FontSize="28" FontWeight="Bold" Foreground="#0F172A" HorizontalAlignment="Right"/>
                                </Grid>
                            </Grid>

                            <UniformGrid Columns="3" Rows="1" Height="55">
                                <Button Command="{Binding PayAndPrintCommand}" Content="PAY &amp; PRINT"
                                        Background="#6366F1" Foreground="White" FontSize="13" FontWeight="Bold"
                                        Margin="0,0,5,0" Cursor="Hand">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>

                                <Button Command="{Binding InitCreditCheckoutCommand}" Content="CREDIT SALE"
                                        Background="#EF4444" Foreground="White" FontSize="13" FontWeight="Bold"
                                        Margin="5,0,5,0" Cursor="Hand">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>

                                <Button Command="{Binding CheckoutCommand}" Content="CHECKOUT"
                                        Background="#059669" Foreground="White" FontSize="13" FontWeight="Bold"
                                        Margin="5,0,0,0" Cursor="Hand">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="0" Grid.ColumnSpan="2" Panel.ZIndex="999" 
              Background="#7F000000" Visibility="{Binding IsNotificationVisible, Converter={StaticResource BoolToVis}}">
            <Border Background="White" Width="400" MinHeight="250" CornerRadius="12" Padding="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.3" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="120"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{Binding NotificationColor}" CornerRadius="12,12,0,0">
                        <TextBlock Text="{Binding NotificationIcon}" FontSize="60" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                    </Border>
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="30,20">
                        <TextBlock Text="{Binding NotificationTitle}" FontSize="22" FontWeight="Bold" 
                                   Foreground="#1E293B" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding NotificationMessage}" FontSize="15" 
                                   Foreground="#64748B" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Button Command="{Binding PrintLastReceiptCommand}" 
                                Visibility="{Binding ShowPrintButtonInNotification, Converter={StaticResource BoolToVis}}"
                                Content="🖨 PRINT RECEIPT" Width="150" Height="45"
                                Background="#3B82F6" Foreground="White" 
                                FontSize="13" FontWeight="Bold" Cursor="Hand" Margin="0,0,10,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="25"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Button Command="{Binding CloseNotificationCommand}" 
                                Content="OK" Width="100" Height="45"
                                Background="{Binding NotificationColor}" Foreground="White" 
                                FontSize="14" FontWeight="Bold" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="25"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Column="0" Grid.ColumnSpan="2" Panel.ZIndex="100" 
              Background="#99000000" Visibility="{Binding IsBatchSelectorVisible, Converter={StaticResource BoolToVis}}">
            <Border Background="White" Width="400" Height="450" CornerRadius="10" Padding="25" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Select Batch" FontSize="18" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,5"/>
                    <TextBlock Grid.Row="1" Text="Multiple stock batches found. Which one to sell?" FontSize="13" Foreground="#64748B" Margin="0,0,0,20"/>
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding AvailableBatches}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.AddBatchToCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                            CommandParameter="{Binding}" Margin="0,0,0,10" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="15">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding PurchaseInvoice.Supplier.Name, TargetNullValue='Unknown Supplier'}" 
                                                                       FontSize="11" Foreground="#0284C7" FontWeight="Bold" Margin="0,0,0,2"/>

                                                            <TextBlock Text="{Binding ReceivedDate, StringFormat='{}Date: {0:dd MMM yyyy}'}" 
                                                                       FontWeight="SemiBold" FontSize="14" Foreground="#334155"/>
                                                            <TextBlock Text="{Binding RemainingQuantity, StringFormat='In Stock: {0}'}" 
                                                                       FontSize="12" Foreground="#94A3B8" Margin="0,2,0,0"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                            <TextBlock Text="{Binding SellingPrice, StringFormat='Rs {0:N2}'}" FontWeight="Bold" FontSize="15" Foreground="#059669" HorizontalAlignment="Right"/>
                                                            <TextBlock Text="{Binding DiscountCode, StringFormat='Code: {0}'}" FontSize="10" FontWeight="Bold" Foreground="#F59E0B" HorizontalAlignment="Right" Margin="0,2,0,0"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F0FDFA"/>
                                                        <Setter Property="BorderBrush" Value="#059669"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <Button Grid.Row="3" Content="Cancel" Command="{Binding CloseBatchSelectorCommand}" Background="#F1F5F9" Foreground="#64748B" FontWeight="SemiBold" Padding="10" Margin="0,15,0,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Column="0" Grid.ColumnSpan="2" Panel.ZIndex="1000" 
              Background="#99000000" Visibility="{Binding IsCustomerPopupVisible, Converter={StaticResource BoolToVis}}">
            <Border Background="White" Width="350" CornerRadius="12" Padding="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.3" Color="Black"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{Binding PopupHeaderColor}" CornerRadius="12,12,0,0" Padding="25,20">
                        <TextBlock Text="{Binding PopupTitleText}" FontSize="18" FontWeight="Bold" Foreground="White"/>
                    </Border>

                    <StackPanel Grid.Row="1" Margin="25">
                        <TextBlock Text="Enter the customer name to record this transaction." FontSize="13" Foreground="#64748B" Margin="0,0,0,20"/>

                        <TextBlock Text="Customer Name" FontSize="12" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding CustomerNameInput, UpdateSourceTrigger=PropertyChanged}" 
                                 Height="40" VerticalContentAlignment="Center" Padding="5" 
                                 BorderBrush="#CBD5E1" BorderThickness="1"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                            <Button Command="{Binding CancelCreditPopupCommand}" Content="Cancel" 
                                    Background="Transparent" Foreground="#64748B" FontWeight="SemiBold" Margin="0,0,10,0"
                                    BorderThickness="0" Cursor="Hand"/>

                            <Button Command="{Binding ConfirmCreditSaleCommand}" Content="CONFIRM &amp; SAVE" 
                                    Background="{Binding PopupHeaderColor}" Foreground="White" FontWeight="Bold" Padding="15,10"
                                    Cursor="Hand">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>