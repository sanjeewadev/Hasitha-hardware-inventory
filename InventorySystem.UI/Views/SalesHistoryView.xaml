<UserControl x:Class="InventorySystem.UI.Views.SalesHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="1100"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Sales History &amp; Logs" FontSize="26" FontWeight="Bold" Foreground="#1E293B"/>
            <TextBlock Text="View and audit past transactions." Foreground="#94A3B8" Margin="0,5,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,15,0">
                    <TextBlock Text="From Date" FontSize="12" Foreground="#64748B" Margin="0,0,0,5"/>
                    <DatePicker SelectedDate="{Binding StartDate}" Width="140" Padding="5" BorderBrush="#E2E8F0"/>
                </StackPanel>

                <StackPanel Margin="0,0,25,0">
                    <TextBlock Text="To Date" FontSize="12" Foreground="#64748B" Margin="0,0,0,5"/>
                    <DatePicker SelectedDate="{Binding EndDate}" Width="140" Padding="5" BorderBrush="#E2E8F0"/>
                </StackPanel>

                <StackPanel Margin="0,0,15,0" VerticalAlignment="Bottom">
                    <TextBlock Text="Search (ID or Product)" FontSize="12" Foreground="#64748B" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Width="200" Height="36" 
                             VerticalContentAlignment="Center" Padding="5" BorderBrush="#E2E8F0" BorderThickness="1"/>
                </StackPanel>

                <Button Command="{Binding SearchCommand}" Content="SEARCH RECORDS" Background="#1E293B" Foreground="White" 
                        Height="36" VerticalAlignment="Bottom" Margin="0,0,10,0" FontSize="12" FontWeight="Bold" Padding="15,0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Command="{Binding ResetFilterCommand}" Content="Reset Filter" Background="Transparent" Foreground="#64748B" 
                        Height="36" VerticalAlignment="Bottom" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="2" ItemsSource="{Binding SalesHistory}" AutoGenerateColumns="False" IsReadOnly="True"
                  Background="White" BorderThickness="1" RowHeight="55"
                  GridLinesVisibility="None" HorizontalGridLinesBrush="Transparent" HeadersVisibility="Column">

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Cursor" Value="Hand"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#F1F5F9"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F8FAFC"/>
                        </Trigger>
                        <DataTrigger Binding="{Binding IsVoided}" Value="True">
                            <Setter Property="Background" Value="#FEF2F2"/>
                            <Setter Property="Foreground" Value="#991B1B"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat='dd MMM yyyy HH:mm'}" Width="150" Foreground="#64748B"/>

                <DataGridTemplateColumn Header="Receipt #" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="{Binding ReferenceId}" 
                                    Command="{Binding DataContext.CopyIdCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding ReferenceId}"
                                    Foreground="#3B82F6" Background="Transparent" BorderThickness="0" 
                                    FontWeight="Bold" Cursor="Hand" ToolTip="Click to Copy ID"
                                    HorizontalContentAlignment="Left"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Sale Summary" Binding="{Binding SummaryText}" Width="*"/>

                <DataGridTextColumn Header="Status" Binding="{Binding StatusDisplay}" Width="190" FontWeight="SemiBold" Foreground="#334155"/>

                <DataGridTextColumn Header="Items" Binding="{Binding TotalItems}" Width="60"/>

                <DataGridTextColumn Header="Total Amount" Binding="{Binding TotalAmount, StringFormat='Rs {0:N2}'}" Width="130" FontWeight="Bold" Foreground="#009688">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextAlignment" Value="Right"/>
                            <Setter Property="Padding" Value="0,0,10,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTemplateColumn Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.ViewDetailsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                    CommandParameter="{Binding}" Padding="0"
                                    Content="👁" Background="#E0F2FE" Foreground="#0284C7" BorderThickness="0" 
                                    Width="35" Height="35" Cursor="Hand" ToolTip="View Details">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="0" Grid.RowSpan="3" Background="#99000000" Panel.ZIndex="100"
              Visibility="{Binding IsDetailsVisible, Converter={StaticResource BoolToVis}}">
            <Border Background="White" Width="550" MaxHeight="650" CornerRadius="10" Padding="30" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <Grid Margin="0,0,0,20">
                            <TextBlock Text="Sale Receipt" FontSize="22" FontWeight="Bold" Foreground="#1E293B"/>
                            <Button Content="{Binding SelectedSale.ReferenceId}" 
                                    Command="{Binding CopyIdCommand}" CommandParameter="{Binding SelectedSale.ReferenceId}"
                                    FontSize="16" FontWeight="Bold" Foreground="#3B82F6" Background="Transparent" 
                                    BorderThickness="0" HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand"/>
                        </Grid>

                        <Border Background="#F8FAFC" Padding="15" CornerRadius="6" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="Status / Date" FontSize="11" Foreground="#94A3B8"/>
                                <TextBlock Text="{Binding SelectedSale.StatusDisplay}" FontSize="14" FontWeight="SemiBold" Foreground="#334155"/>
                                <TextBlock Text="{Binding SelectedSale.Date, StringFormat='dd MMM yyyy - hh:mm tt'}" FontSize="12" Foreground="#64748B" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding SelectedSale.Items}" AutoGenerateColumns="False" IsReadOnly="True"
                              BorderThickness="0" Background="White" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9"
                              HeadersVisibility="Column" Margin="0,0,0,20" RowHeight="45">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Item" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTemplateColumn Header="Qty" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Quantity}" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Unit}" FontSize="10" Foreground="Gray" Margin="3,0,0,0" VerticalAlignment="Bottom"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Price" Binding="{Binding UnitPrice, StringFormat=N2}" Width="90"/>
                            <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=N2}" Width="90" FontWeight="Bold"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="2" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Content="🖨 PRINT RECEIPT" Command="{Binding PrintReceiptCommand}" 
                                Background="#009688" Foreground="White" FontWeight="Bold" Height="45" 
                                HorizontalAlignment="Left" Padding="20,0" Cursor="Hand" BorderThickness="0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Button Grid.Column="1" Content="Close" Command="{Binding CloseDetailsCommand}" 
                                Background="#F1F5F9" Foreground="#64748B" FontWeight="SemiBold" Height="45" 
                                Padding="25,0" Cursor="Hand" BorderThickness="0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="6"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>