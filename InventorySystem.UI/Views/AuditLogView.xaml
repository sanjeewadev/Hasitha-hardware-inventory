<UserControl x:Class="InventorySystem.UI.Views.AuditLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="1100"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Audit Log: Voids &amp; Returns" FontSize="26" FontWeight="Bold" Foreground="#1E293B"/>
            <TextBlock Text="Monitor cancelled sales and customer refunds." FontSize="14" Foreground="#64748B" Margin="0,5,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,20" BorderBrush="#E2E8F0" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,15,0">
                    <TextBlock Text="From Date" FontSize="12" Foreground="#64748B" Margin="0,0,0,5"/>
                    <DatePicker SelectedDate="{Binding StartDate}" Width="140" Padding="5" BorderBrush="#E2E8F0"/>
                </StackPanel>

                <StackPanel Margin="0,0,25,0">
                    <TextBlock Text="To Date" FontSize="12" Foreground="#64748B" Margin="0,0,0,5"/>
                    <DatePicker SelectedDate="{Binding EndDate}" Width="140" Padding="5" BorderBrush="#E2E8F0"/>
                </StackPanel>

                <StackPanel Margin="0,0,15,0" VerticalAlignment="Bottom">
                    <TextBlock Text="Search Receipt ID or Product" FontSize="12" Foreground="#64748B" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Width="250" Height="36" 
                             VerticalContentAlignment="Center" Padding="8,0" BorderBrush="#E2E8F0" BorderThickness="1"/>
                </StackPanel>

                <Button Command="{Binding SearchCommand}" Content="FILTER RECORDS" Background="#1E293B" Foreground="White" 
                        Height="36" VerticalAlignment="Bottom" Margin="0,0,10,0" FontSize="12" FontWeight="Bold" Padding="15,0" BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Command="{Binding ResetFilterCommand}" Content="Reset" Background="Transparent" Foreground="#64748B" 
                        Height="36" VerticalAlignment="Bottom" BorderThickness="0" Cursor="Hand" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="2" ItemsSource="{Binding AuditLogs}" AutoGenerateColumns="False" IsReadOnly="True"
                  Background="White" BorderThickness="1" BorderBrush="#E2E8F0" RowHeight="55"
                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9" HeadersVisibility="Column">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#F8FAFC"/>
                    <Setter Property="Padding" Value="15,0"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Foreground" Value="#64748B"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                    <Setter Property="Height" Value="45"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat='dd MMM yyyy HH:mm'}" Width="180" Foreground="#475569"/>

                <DataGridTextColumn Header="Receipt #" Binding="{Binding ReceiptId}" Width="190" FontWeight="Bold" Foreground="#334155"/>

                <DataGridTemplateColumn Header="Action Type" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="{Binding ActionBgColor}" Padding="10,4" CornerRadius="4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Text="{Binding ActionType}" Foreground="{Binding ActionColor}" FontWeight="Bold" FontSize="12"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Items Affected" Binding="{Binding TotalItems}" Width="150"/>

                <DataGridTextColumn Header="Impact Value" Binding="{Binding TotalValue, StringFormat='Rs {0:N2}'}" Width="170" FontWeight="Bold" Foreground="#1E293B"/>

                <DataGridTemplateColumn Header="Details" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.ViewDetailsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                    CommandParameter="{Binding}" Content="VIEW ITEMS" Background="#F1F5F9" Foreground="#3B82F6" 
                                    FontWeight="Bold" FontSize="11" Padding="12,6" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Left">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="0" Grid.RowSpan="3" Background="#99000000" Panel.ZIndex="100"
              Visibility="{Binding IsDetailsVisible, Converter={StaticResource BoolToVis}}">
            <Border Background="White" Width="600" MaxHeight="600" CornerRadius="10" Padding="30" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        <TextBlock Text="Audit Details" FontSize="22" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock FontSize="14" Foreground="#64748B" Margin="0,5,0,0">
                            <Run Text="Receipt: "/>
                            <Run Text="{Binding SelectedLog.ReceiptId}" FontWeight="Bold" Foreground="#3B82F6"/>
                        </TextBlock>
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding SelectedLog.Items}" AutoGenerateColumns="False" IsReadOnly="True"
                              BorderThickness="1" BorderBrush="#E2E8F0" Background="White" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9"
                              HeadersVisibility="Column" RowHeight="45">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F8FAFC"/>
                                <Setter Property="Padding" Value="10,0"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="#64748B"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="60" FontWeight="Bold"/>
                            <DataGridTextColumn Header="Value" Binding="{Binding Total, StringFormat=N2}" Width="90"/>
                            <DataGridTextColumn Header="Logged Reason / Note" Binding="{Binding Reason}" Width="150" Foreground="#94A3B8"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Button Grid.Row="2" Content="CLOSE" Command="{Binding CloseDetailsCommand}" 
                            Background="#1E293B" Foreground="White" FontWeight="Bold" Height="40" Width="100" 
                            HorizontalAlignment="Right" Margin="0,20,0,0" Cursor="Hand" BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>